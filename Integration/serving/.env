# Redis (Speed Layer)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_REALTIME_PREFIX=realtime:stats

# Watermark escrito por el batch (idealmente en Redis)
WATERMARK_KEY=batch:watermark

# Hive (Batch Layer) via HiveServer2 (tu compose expone 10000:10000)
HIVE_HOST=localhost
HIVE_PORT=10000
HIVE_USERNAME=hive
HIVE_DATABASE=default

# Tabla principal en Hive (ajústala cuando crees tus tablas externas/curadas)
HIVE_EVENTS_TABLE=ecommerce_events